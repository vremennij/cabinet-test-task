{
  "openapi": "3.0.0",
  "info": {
    "title": "Кабинет - тестовое задание",
    "description": "Модуль подачи и отбора заявок на проект от внешних участников. Читайте более подробное описание в самих ручках",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000/"
    }
  ],
  "security": [
    {
      "BEARER": []
    }
  ],
  "paths": {
    "/login": {
      "post": {
        "tags": [
          "Безопасность"
        ],
        "summary": "Вход в систему",
        "description": "Авторизовать пользователя по логину и паролю. В моковой базе добавьте двух пользователей: с ролью админа и без неё",
        "operationId": "postLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "login": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Логин пользователя"
                  },
                  "password": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Пароль пользователя"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "description": "JWT-токен пользователя"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "desctiption": "Ошибка авторизации"
          }
        }
      }
    },

    "/project/type": {
      "get": {
        "tags": [
          "Заявка на проект - Внешняя заявка"
        ],
        "summary": "Возвращает все типы проектов (доступна всем пользователям)",
        "description": "Просто список доступных типов проектов. В моковом наполнении базы добавьте пару типов проектов для демонстрации",
        "operationId": "getProjectDictionaryGetProjectTypes",
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ProjectTypeModel"
                  },
                  "nullable": false
                }
              }
            }
          }
        }
      }
    },
    "/project/application/external": {
      "post": {
        "tags": [
          "Заявка на проект - Внешняя заявка"
        ],
        "summary": "Подать заявку на проект от внешнего инициатора (доступна всем пользователям)",
        "description": "Тут внешний инициатор передаёт основную информацию о проекте и отправляет заявку на рассмотрение",
        "operationId": "postProjectApplicationExternalApplicationCreateExternalProjectApplication",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateExternalApplicationModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возращает Id созданной заявки",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer"
                }
              }
            }
          }
        }
      }
    },
    "/project/application/external/{applicationId}": {
      "get": {
        "tags": [
          "Внешняя заявка на проект"
        ],
        "summary": "Получить внешнюю заявку (доступна пользователям с ролью \"ADMIN\")",
        "description": "getProjectApplicationExternalApplicationGetExternalApplication",
        "operationId": "getProjectApplicationExternalApplicationGetExternalApplication",
        "parameters": [
          {
            "name": "applicationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "nullable": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExternalApplicationModel"
                }
              }
            }
          },
          "404": {
            "description": "Заявка не найдена"
          },
          "401": {
            "description": "Пользователь неавторизован"
          },
          "403": {
            "description": "У пользователя нет роли администратора"
          }
        }
      }
    },
    "/project/application/external/{applicationId}/reject": {
      "post": {
        "tags": [
          "Внешняя заявка на проект"
        ],
        "summary": "Отклонить внешнюю заявку (доступна пользователям с ролью \"ADMIN\")",
        "description": "Переводит внешнюю заявку из статуса \"PENDING\" в статус \"REJECTED\"",
        "operationId": "postProjectApplicationExternalApplicationRejectExternalApplication",
        "parameters": [
          {
            "name": "applicationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "nullable": false
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReasonModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Успешно"
          },
          "400": {
            "description": "Заявка находится не в статусе \"PENDING\""
          },
          "404": {
            "description": "Заявка не найдена"
          },
          "401": {
            "description": "Пользователь неавторизован"
          },
          "403": {
            "description": "У пользователя нет роли администратора"
          }
        }
      }
    },
    "/project/application/external/{applicationId}/accept": {
      "post": {
        "tags": [
          "Внешняя заявка на проект"
        ],
        "summary": "Принять внешнюю заявку (доступна пользователям с ролью \"ADMIN\")",
        "description": "Переводит внешнюю заявку из статуса \"PENDING\" в статус \"ACCEPTED\"",
        "operationId": "postProjectApplicationExternalApplicationAcceptExternalApplication",
        "parameters": [
          {
            "name": "applicationId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "nullable": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешно"
          },
          "400": {
            "description": "Заявка не находится в статусе \"PENDING\""
          },
          "404": {
            "description": "Заявка не найдена"
          },
          "401": {
            "description": "Пользователь неавторизован"
          },
          "403": {
            "description": "У пользователя нет роли администратора"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssignManagerModel": {
        "required": [
          "managerId"
        ],
        "properties": {
          "managerId": {
            "title": "Id руководителя проекта",
            "type": "integer"
          },
          "directionManagerId": {
            "title": "Id руководителя направления",
            "type": "integer",
            "default": null,
            "nullable": true
          }
        },
        "type": "object"
      },
      "CreateExternalApplicationModel": {
        "required": [
          "fullName",
          "email",
          "organisationName",
          "projectName",
          "typeId",
          "expectedResults",
          "isPayed"
        ],
        "properties": {
          "fullName": {
            "title": "ФИО заказчика",
            "type": "string",
            "maxLength": 150
          },
          "email": {
            "title": "Адрес почты заказчика",
            "type": "string",
            "maxLength": 150
          },
          "phone": {
            "title": "Номер телефона заказчика",
            "type": "string",
            "pattern": ".*\\+7\\s\\(\\d\\d\\d\\)\\s\\d\\d\\d-\\d\\d-\\d\\d.*",
            "nullable": true
          },
          "organisationName": {
            "title": "Название организации",
            "type": "string",
            "maxLength": 150
          },
          "organisationUrl": {
            "title": "Ссылка на сайт организации",
            "type": "string",
            "nullable": true
          },
          "projectName": {
            "title": "Название проекта",
            "type": "string",
            "maxLength": 150
          },
          "typeId": {
            "title": "Id типа проекта",
            "type": "integer"
          },
          "expectedResults": {
            "title": "Ожидаемые результаты",
            "type": "string",
            "maxLength": 1500
          },
          "isPayed": {
            "title": "Предполагается ли оплата",
            "type": "boolean"
          },
          "additionalInformation": {
            "title": "Дополнительная информация",
            "type": "string",
            "maxLength": 1500,
            "nullable": true
          },
          "rejectedReason": {
            "title": "Причина отклонения заявки",
            "type": "string",
            "maxLength": 750,
            "nullable": true
          }
        },
        "type": "object"
      },
      "ExternalApplicationModel": {
        "required": [
          "applicationId",
          "initiator",
          "email",
          "organisationName",
          "projectName",
          "typeName",
          "expectedResults",
          "isPayed",
          "status"
        ],
        "properties": {
          "applicationId": {
            "title": "Id внешней заявки",
            "type": "integer"
          },
          "initiator": {
            "title": "Инициатор проекта",
            "type": "string"
          },
          "email": {
            "title": "Адрес почты инициатора",
            "type": "string"
          },
          "phone": {
            "title": "Номер телефона инициатора",
            "type": "string",
            "nullable": true
          },
          "organisationName": {
            "title": "Название организации",
            "type": "string"
          },
          "organisationUrl": {
            "title": "Ссылка на сайт организации",
            "type": "string",
            "nullable": true
          },
          "projectName": {
            "title": "Название проекта",
            "type": "string"
          },
          "typeName": {
            "title": "Тип проекта",
            "type": "string"
          },
          "expectedResults": {
            "title": "Ожидаемые результаты",
            "type": "string"
          },
          "isPayed": {
            "title": "Предполагается ли оплата",
            "type": "boolean"
          },
          "additionalInformation": {
            "title": "Дополнительная информация",
            "type": "string",
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/ExternalApplicationStatus"
          }
        },
        "type": "object"
      },
      "ExternalApplicationStatus": {
        "type": "string",
        "enum": [
          "PENDING",
          "ACCEPTED",
          "REJECTED"
        ]
      },
      "ProjectTypeModel": {
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "title": "Id типа проекта",
            "type": "integer"
          },
          "name": {
            "title": "Полное имя типа проекта",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ReasonModel": {
        "required": [
          "reason"
        ],
        "properties": {
          "reason": {
            "title": "Причина отклонения заявки",
            "type": "string",
            "maxLength": 750
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "BEARER": {
        "type": "apiKey",
        "name": "X-API-TOKEN",
        "in": "header",
        "bearerFormat": "JWT",
        "scheme": "bearer"
      }
    }
  }
}